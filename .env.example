# =====================================================================
# Plantilla de variables de entorno para ProyectoSpring.
# Copia este archivo a `.env` (ignorado por git) y rellena los valores
# reales, o expórtalos en tu entorno / configúralos en tu plataforma.
# NUNCA subas credenciales reales al repositorio.
# =====================================================================

# Perfil activo: dev (por defecto) o prod
SPRING_PROFILES_ACTIVE=dev

# --- Base de datos MySQL ---
DB_URL=jdbc:mysql://localhost:3306/alumnos_db
DB_USERNAME=alumnos_user
DB_PASSWORD=tu_password_de_mysql
# Solo lo usa docker-compose para el contenedor MySQL (usuario root)
DB_ROOT_PASSWORD=tu_password_root_de_mysql

# --- Seguridad JWT ---
# Debe tener al menos 32 bytes (256 bits) para HS256
JWT_SECRET=genera-una-clave-larga-y-aleatoria-de-al-menos-32-bytes
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# --- Usuario administrador inicial (se siembra al arrancar) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=define-una-password-segura
